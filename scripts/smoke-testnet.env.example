# cards402 testnet smoke test — environment template
# Copy to smoke-testnet.env and fill in values. Do not commit the real file.
#
# Run with:
#   source scripts/smoke-testnet.env && node scripts/smoke-testnet.mjs

# ── Required ─────────────────────────────────────────────────────────────────

# cards402 backend API base (must include /v1 suffix)
export CARDS402_API_BASE=http://localhost:4000/v1

# API key for the target backend. Create one via the admin dashboard.
export CARDS402_API_KEY=cards402_...

# Stellar secret key (S...) funded with testnet USDC + a bit of XLM for fees.
# Get testnet USDC from https://circle.com/faucet and XLM from friendbot.
export STELLAR_WALLET_SECRET=S...

# ── Optional ─────────────────────────────────────────────────────────────────

# Network — 'testnet' (default) or 'mainnet'. Mainnet requires real funds.
export STELLAR_NETWORK=testnet

# Custom Soroban RPC endpoint. Omit to use the default for the chosen network.
# export SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Amount in USDC (max 2 decimal places, e.g. "0.01"). Keep this small for smoke tests.
export AMOUNT_USDC=0.10

# Payment asset — 'usdc' (default) or 'xlm'.
export PAYMENT_ASSET=usdc

# How long to poll for the card before giving up. Default 5 minutes.
export TIMEOUT_MS=300000
