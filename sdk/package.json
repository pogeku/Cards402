{
  "name": "cards402",
  "version": "0.1.0",
  "description": "Virtual Visa cards for AI agents — pay USDC or XLM on Stellar",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./mcp": {
      "import": "./dist/mcp.js",
      "types": "./dist/mcp.d.ts"
    }
  },
  "bin": {
    "cards402-mcp": "./dist/mcp.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "stellar",
    "usdc",
    "xlm",
    "virtual-card",
    "vcc",
    "visa",
    "ai-agent",
    "mcp",
    "model-context-protocol",
    "402-payment",
    "soroban",
    "cards402"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cards402/cards402"
  },
  "homepage": "https://cards402.com",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@open-wallet-standard/core": "file:open-wallet-standard-core-1.2.4.tgz",
    "@stellar/stellar-sdk": "^15.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.3",
    "typescript": "^5.0.0",
    "vitest": "^4.1.3"
  }
}
